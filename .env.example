# Copy this file to ".env" and fill in the values from your Supabase project
# (Dashboard → Project Settings → API). The .env file is gitignored — never commit it.

# Project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# The "anon / public" key (safe for the frontend — protected by row-level security)
VITE_SUPABASE_ANON_KEY=

# Your deployed AI proxy function URL, e.g.
# https://abcdefgh.supabase.co/functions/v1/generate
# Leave blank to keep using the direct bring-your-own-key path.
VITE_AI_PROXY_URL=

# Your deployed billing function URL, e.g.
# https://abcdefgh.supabase.co/functions/v1/billing
# Leave blank to keep the app open (no paywall) until billing is set up.
VITE_BILLING_URL=
